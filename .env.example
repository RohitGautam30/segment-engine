# Copy to backend/.env — the backend reads its own .env from that folder.
# The frontend needs no env vars in development; Vite proxies /api to :4000.

NODE_ENV=development
PORT=4000
APP_NAME=segment-engine

MONGO_URI=mongodb://127.0.0.1:27017/segment_engine
MONGO_MAX_POOL=20

# Both must be at least 32 characters or the server refuses to boot.
JWT_ACCESS_SECRET=dev_only_access_secret_change_me_32chars
JWT_REFRESH_SECRET=dev_only_refresh_secret_change_me_32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

INGEST_API_KEYS=pk_live_demo_key_1,pk_live_demo_key_2

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
INGEST_RATE_LIMIT_MAX=2000

# Vite dev server. Only needed if you bypass the proxy and call :4000 directly.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WORKER_ENABLED=true
WORKER_CONCURRENCY=5
WORKER_POLL_MS=1000
CAMPAIGN_BATCH_SIZE=500

SCORE_RECOMPUTE_CRON_MINUTES=60
COHORT_REFRESH_MINUTES=15

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
